{
  "name": "rinku",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@rinku/web",
    "dev:mobile": "turbo run dev --filter=@rinku/mobile",
    "dev:api": "turbo run dev --filter=@rinku/api",
    "build": "turbo run build",
    "start": "pnpm --filter @rinku/web start",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.10.0"
  }
}
